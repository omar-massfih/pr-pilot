# Repository where feature branches and pull requests will be created.
repo = "/absolute/path/to/your/repository"
state_dir = "~/.pr-pilot"

# Optional: let one bot drive several repos, switched from Telegram with
# `/repo <name>` (the first is the default). When set, `repo` above may be
# omitted — the first entry becomes the default. Give each instance its own
# state_dir so their run history / offsets don't collide.
# [repos]
# frontend = "/home/you/site"
# backend  = "/home/you/site-backend"

# Optional group mode: set `workspace` to a dir that CONTAINS every [repos] entry.
# The agent then runs in that workspace and sees/edits all members at once (for
# full-stack features), and a PR is opened per member repo that actually changed.
# Omit it to keep the repos independent (/repo-switchable). Example layout:
#   workspace = "/home/you/site-workspace"   # contains frontend/ and backend/
# [repos]
#   frontend = "/home/you/site-workspace/frontend"
#   backend  = "/home/you/site-workspace/backend"

# Providers: "codex" or "cursor" (their CLIs, needing `codex`/`cursor-agent` on
# PATH), "chatgpt" — chatgpt.com's backend over HTTP, reusing the OAuth tokens
# from `codex login` (~/.codex/auth.json), no extra binary — or "opencode", the
# opencode CLI headless. chatgpt drives the repo through pr-pilot's own
# inspect/edit loop; opencode brings its own agent loop and native tool calling,
# so it offloads the coding — point it at any OpenAI-compatible endpoint via
# ~/.config/opencode/opencode.json and set model to a "provider/model" slug (e.g.
# "chatgpt-proxy/gpt-5.5"). Read-only roles use opencode's built-in `plan` agent;
# writing roles run the build agent with --auto. Model ids must be codex-supported.
[implementer]
name = "codex"
# model = "optional-model-name"
# chatgpt only — reasoning effort per round: minimal | low | medium | high.
# Lower is faster; "low" (default) trades some thoroughness for speed.
# reasoning_effort = "low"
limit_poll_seconds = 60
limit_max_wait_seconds = 0 # 0 waits indefinitely; Ctrl-C still stops immediately.

[reviewer]
# A different provider than the implementer is optional, but gives stronger independence.
name = "cursor"
# model = "optional-model-name"
limit_poll_seconds = 60
limit_max_wait_seconds = 0

# [designer]
# Proposes the next feature in the /auto loop (read-only; reads ROADMAP.md and
# the codebase to pick a roadmap-coherent next step). Omit this table entirely to
# reuse the [implementer] provider/model/effort. Override it to design on a
# different provider or a higher reasoning effort than you implement with.
# name = "chatgpt"
# reasoning_effort = "high"

[github]
base_branch = "main"
draft = true

[workflow]
max_review_attempts = 3

[babysit]
enabled = true
interval_seconds = 30
max_cycles = 60
max_fix_attempts = 3
require_approval = false

[memory]
enabled = true
database = "~/.pr-pilot/memory.db"
embedding_model = "BAAI/bge-small-en-v1.5"
profile_provider = "implementer"
max_file_bytes = 524288
chunk_chars = 1600
chunk_overlap = 200
context_results = 10
context_chars = 12000
relationship_depth = 1
relationship_threshold = 0.80

[telegram]
token_env = "TELEGRAM_BOT_TOKEN"
allowed_chat_ids = [123456789]
